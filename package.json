{
  "name": "onkoray-website",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:a11y": "pa11y-ci",
    "test:lighthouse": "lhci autorun",
    "ci:local": "npm run lint && npm run format:check && npm run check && npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,ts,astro}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/vercel": "^10.0.7",
    "@resvg/resvg-js": "^2.6.2",
    "astro": "^6.3.7",
    "astro-icon": "^1.1.5",
    "gsap": "^3.15.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "postcss-import": "^16.1.1",
    "postcss-import-ext-glob": "^2.1.1",
    "satori": "^0.26.0",
    "utopia-core": "^1.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/cli": "^4.11.3",
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint/js": "^9.39.4",
    "@lhci/cli": "^0.15.1",
    "astro-compressor": "^1.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.3.0",
    "pa11y-ci": "^4.1.1",
    "postcss-preset-env": "^11.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "schema-dts": "^2.0.0",
    "sharp": "^0.34.5",
    "start-server-and-test": "^3.0.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.4"
  },
  "browserslist": [
    "> 0.5% and not dead and supports css-media-range-syntax"
  ],
  "engines": {
    "node": "^22.12.0 || >=24.0.0",
    "npm": ">=10.9.4"
  }
}

---
interface Props {
  href?: string;
  label?: string;
}

const { href = "#main-content", label = "Zum Hauptinhalt springen" } =
  Astro.props;
---

<a class="skip-link" href={href}>{label}</a>

<style>
  .skip-link {
    position: absolute;
    inset-inline-start: 0.5rem;
    inset-block-start: 0.5rem;
    z-index: 1000;

    padding: 0.5rem 1rem;
    background: var(--color-black, #000);
    color: var(--color-white, #fff);
    text-decoration: none;
    border-radius: 0.25rem;

    /* Visually hidden until focused. */
    clip-path: inset(50%);
    width: 1px;
    height: 1px;
    overflow: hidden;
    white-space: nowrap;

    &:focus {
      clip-path: none;
      width: auto;
      height: auto;
    }
  }
</style>

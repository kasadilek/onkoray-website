# Canonical base URL used for sitemap, canonical links, OG images.
# Include scheme, no trailing slash. Required in production.
PUBLIC_SITE_URL=https://onkoray.de

# Human-readable site name used as fallback title, OG site_name, JSON-LD Organization.
PUBLIC_SITE_NAME=OnkoRay

# Default locale used for <html lang> and OG locale. BCP 47 tag.
PUBLIC_DEFAULT_LOCALE=de

# Analytics provider loaded by <BaseHead>. One of: plausible | vercel | none.
# 'plausible' is cookieless. 'vercel' requires @vercel/analytics. 'none' skips injection.
PUBLIC_ANALYTICS_PROVIDER=none
